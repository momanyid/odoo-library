<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_library_borrow_form" model="ir.ui.view">
        <field name="name">library.borrow.form</field>
        <field name="model">library.borrow</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                    <button name="action_return" string="Return Book" type="object" invisible="state not in ('active', 'overdue')"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="book_id"/>
                            <field name="member_id"/>
                        </group>
                        <group>
                            <field name="borrow_date"/>
                            <field name="due_date"/>
                            <field name="return_date"/>
                            <field name="is_overdue"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_library_borrow_list" model="ir.ui.view">
        <field name="name">library.borrow.list</field>
        <field name="model">library.borrow</field>
        <field name="arch" type="xml">
            <list>
                <field name="book_id"/>
                <field name="member_id"/>
                <field name="borrow_date"/>
                <field name="due_date"/>
                <field name="state"/>
                <field name="is_overdue"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_library_borrow_search" model="ir.ui.view">
        <field name="name">library.borrow.search</field>
        <field name="model">library.borrow</field>
        <field name="arch" type="xml">
            <search>
                <field name="book_id"/>
                <field name="member_id"/>
                <filter name="active" string="Active" domain="[('state','=','active')]"/>
                <filter name="returned" string="Returned" domain="[('state','=','returned')]"/>
                <filter name="overdue" string="Overdue" domain="[('state','=','overdue')]"/>
                <filter name="is_overdue" string="Overdue Today" domain="[('is_overdue','=',True)]"/>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="anqad_library_david.action_library_borrow" model="ir.actions.act_window">
        <field name="name">Borrow Transactions</field>
        <field name="res_model">library.borrow</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>