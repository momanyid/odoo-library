<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="title"/>
                            <field name="isbn"/>
                            <field name="author_id"/>
                        </group>
                        <group>
                            <field name="genre"/>
                            <field name="publish_date"/>
                            <field name="available_copies"/>
                            <field name="total_borrows"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_library_book_list" model="ir.ui.view">
        <field name="name">library.book.list</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list>
                <field name="title"/>
                <field name="author_id"/>
                <field name="genre"/>
                <field name="state"/>
                <field name="available_copies"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_library_book_search" model="ir.ui.view">
        <field name="name">library.book.search</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <search>
                <field name="title"/>
                <field name="author_id"/>
                <filter name="available" string="Available" domain="[('state','=','available')]"/>
                <filter name="borrowed" string="Borrowed" domain="[('state','=','borrowed')]"/>
                <filter name="group_genre" string="Genre" context="{'group_by':'genre'}"/>
            </search>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_library_book_kanban" model="ir.ui.view">
        <field name="name">library.book.kanban</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <kanban default_group_by="genre">
                <field name="title"/>
                <field name="author_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <field name="title" class="fw-bold"/>
                        <field name="author_id"/>
                        <field name="state"/>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Window Action -->
    <record id="anqad_library_david.action_library_book" model="ir.actions.act_window">
        <field name="name">Books</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">list,kanban,form</field>
    </record>
</odoo>