<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Authors -->
    <record id="author_1" model="library.author">
        <field name="name">George Orwell</field>
        <field name="email">gorwell@example.com</field>
    </record>
    <record id="author_2" model="library.author">
        <field name="name">Yuval Harari</field>
        <field name="email">yharari@example.com</field>
    </record>
    <record id="author_3" model="library.author">
        <field name="name">Ada Lovelace</field>
        <field name="email">ada@example.com</field>
    </record>

    <!-- Books -->
    <record id="book_1" model="library.book">
        <field name="title">1984</field>
        <field name="isbn">978-0451524935</field>
        <field name="author_id" ref="author_1"/>
        <field name="genre">fiction</field>
        <field name="available_copies">3</field>
    </record>
    <record id="book_2" model="library.book">
        <field name="title">Animal Farm</field>
        <field name="isbn">978-0451526342</field>
        <field name="author_id" ref="author_1"/>
        <field name="genre">fiction</field>
        <field name="available_copies">2</field>
    </record>
    <record id="book_3" model="library.book">
        <field name="title">Sapiens</field>
        <field name="isbn">978-0062316097</field>
        <field name="author_id" ref="author_2"/>
        <field name="genre">history</field>
        <field name="available_copies">2</field>
    </record>

    <!-- Members -->
    <record id="member_1" model="library.member">
        <field name="name">Alice Wanjiku</field>
        <field name="email">alice@example.com</field>
        <field name="phone">0712000001</field>
    </record>
    <record id="member_2" model="library.member">
        <field name="name">Bob Otieno</field>
        <field name="email">bob@example.com</field>
        <field name="phone">0712000002</field>
    </record>
</odoo>